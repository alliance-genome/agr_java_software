  public void indexAlleleVariantSeq(List<AlleleVariantSequence> docs) throws IOException {
      BulkRequest bulkRequest=new BulkRequest();
      bulkRequest.setRefreshPolicy(WriteRequest.RefreshPolicy.IMMEDIATE);
      // bulkRequest.setRefreshPolicy(WriteRequest.RefreshPolicy.WAIT_UNTIL);
      bulkRequest.timeout(TimeValue.timeValueMinutes(1));
      bulkRequest.timeout("1m");

      for(AlleleVariantSequence d:docs){
        //  d.setCategory("allele");
          ObjectMapper mapper=new ObjectMapper();
      //    mapper.setSerializationInclusion(JsonInclude.Include.NON_NULL);
      //    mapper.setSerializationInclusion(JsonInclude.Include.NON_EMPTY);

          try {

              String json = mapper.writeValueAsString(d);
              System.out.println(json);
             bulkRequest.add(new IndexRequest(SourceDocumentCreationNew.indexName).source(json, XContentType.JSON));

          }catch (Exception e){
              e.printStackTrace();
          }

      }
      try {
        EsClientFactory.getDefaultEsClient().bulk(bulkRequest, RequestOptions.DEFAULT);
          RefreshRequest req=new RefreshRequest();
           EsClientFactory.getDefaultEsClient().indices().refresh(req, RequestOptions.DEFAULT);

      }catch (Exception e){}
  }


    public void index(List<VariantDocument> docs) throws IOException {
        BulkRequest bulkRequest=new BulkRequest();
       bulkRequest.setRefreshPolicy(WriteRequest.RefreshPolicy.IMMEDIATE);
       // bulkRequest.setRefreshPolicy(WriteRequest.RefreshPolicy.WAIT_UNTIL);
        bulkRequest.timeout(TimeValue.timeValueMinutes(1));
        bulkRequest.timeout("1m");
        for(VariantDocument d:docs){
            ObjectMapper mapper=new ObjectMapper();
            try {
                byte[] json = mapper.writeValueAsBytes(d);
                bulkRequest.add(new IndexRequest(SourceDocumentCreation.indexName).source(json, XContentType.JSON));
            }catch (Exception e){
                e.printStackTrace();
            }

        }
        try {
            EsClientFactory.getDefaultEsClient().bulk(bulkRequest, RequestOptions.DEFAULT);
            //  EsClientFactory.closeClient();
            //  client.indices().refresh(refreshRequest, RequestOptions.DEFAULT);
        }catch (Exception e){}
    }
